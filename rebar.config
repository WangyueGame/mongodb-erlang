%% ex: ts=4 sw=4 noexpandtab syntax=erlang

{erl_opts, [debug_info, fail_on_warning]}.
{minimum_otp_vsn, "27"}.
{edoc_opts, [{index_columns, 1}, {sort_functions, false}, {preprocess, true}]}.
{dialyzer, [
  {plt_apps, top_level_deps},
  {plt_extra_apps, [ssl]}
]}.

{deps, [
  {bson, ".*",
   {git, "https://github.com/WangyueGame/bson-erlang.git", {tag, "v0.3.0"}}},
  {poolboy, ".*",
   {git, "https://github.com/comtihon/poolboy.git", {branch, "1.6.1"}}}
]}.

{profiles, [
  {test, [
    {deps, [
      {proper, "1.4.0"}
    ]}
  ]}
]}.

{clean_files, [
  "erl_crash.dump",
  "doc/*.html",
  "doc/erlang.png",
  "doc/edoc-info",
  "doc/stylesheet.css"
]}.
